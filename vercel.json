{
  "version": 2,
  "builds": [
    {
      "src": "best4life/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/health",
      "dest": "api/index.py"
    },
    {
      "src": "/auth/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/profile",
      "dest": "api/index.py"
    },
    {
      "src": "/profile/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/meal-plans",
      "dest": "api/index.py"
    },
    {
      "src": "/meal-plans/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/shopping-lists",
      "dest": "api/index.py"
    },
    {
      "src": "/shopping-lists/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/app/state",
      "dest": "api/index.py"
    },
    {
      "src": "/app/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/best4life/assets/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/best4life/index.html"
    }
  ]
}